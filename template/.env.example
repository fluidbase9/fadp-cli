# ── FLDP Developer Keys (generated by fadp-cli setup) ──────────────────────────
# Copy your values from .env.fadp into here, or load .env.fadp directly.

FLDP_API_KEY_NAME="fluid/devkeys/YOUR_ORG/YOUR_KEY_ID"
FLDP_API_KEY_PRIVATE_KEY='{"name":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n...","publicKey":"...","type":"fldp_api_key","createdAt":"..."}'

# ── Server config ───────────────────────────────────────────────────────────────
PORT=3001
FADP_PRICE_USDC="0.01"          # price in USDC to call the gated endpoint
FLUID_API_URL="https://fluidnative.com"
