# ── Fluid Agent Key (REQUIRED) ────────────────────────────────────────────────
# Generated by fadp-cli Step 3. Shown ONCE in terminal — save it immediately.
# Fluid stores only SHA256(this key) — never the raw value. Never commit this file.
FLUID_AGENT_KEY="fwag_replace_with_your_key_here"

# ── Payment receiver address (for server.js paywall) ──────────────────────────
# Your Fluid Wallet address on Base mainnet — this is WHERE payments are sent TO.
# Find it: log in to fluidnative.com → Settings → Wallet Address
# Without this, server runs in dev/offline mode (skips on-chain verification).
FADP_WALLET_ADDRESS="0x_your_wallet_address_on_base_here"

# ── FLDP developer key pair (built, not yet enforced on routes) ───────────────
# Generated by fadp-cli Step 2. Used to authenticate to Fluid developer API.
FLDP_API_KEY_NAME="fluid/devkeys/YOUR_ORG/YOUR_KEY_ID"
FLDP_API_KEY_PRIVATE_KEY='{"name":"...","privateKey":"-----BEGIN PRIVATE KEY-----\n..."}'

# ── Optional server config ─────────────────────────────────────────────────────
PORT=3001
FADP_PRICE_USDC="0.01"
FLUID_API_URL="https://fluidnative.com"
